{
  "name": "epm-crm-fullstack",
  "version": "1.0.0",
  "description": "Unified build for EPM CRM Mail Sync",
  "main": "backend/src/index.js",
  "scripts": {
    "install-frontend": "npm install --prefix frontend --legacy-peer-deps",
    "install-backend": "npm install --prefix backend --legacy-peer-deps",
    "build-frontend": "npm run build --prefix frontend",
    "build": "npm run install-frontend && npm run build-frontend && npm run install-backend",
    "start": "node backend/src/index.js",
    "dev": "npm run dev --prefix backend"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
